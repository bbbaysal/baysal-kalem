<?xml version="1.0" encoding="utf-8"?>
<component type="desktop-application">
  <id>tr.org.baysal.kalem</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0+</project_license>
  <name>Baysal Kalem</name>
  <name xml:lang="tr">Baysal Kalem</name>
  <summary>Screen Drawing Tool</summary>
  <summary xml:lang="tr">Ekran Çizim Aracı</summary>
  <developer_name translate="no">Bekir Bergin BAYSAL</developer_name>
  <developer id="bekirberginbaysal@gmail.com">
    <name translate="no">Bekir Bergin BAYSAL</name>
  </developer>
  <description>
    <p>A simple and easy whiteboard pen application</p>
    <p xml:lang="tr">Basit ve kolay bir beyaz tahta kalemi uygulaması</p>
  </description>
  <launchable type="desktop-id">tr.org.baysal.kalem.desktop</launchable>
  <url type="homepage">https://bekirberginbaysal.blogspot.com/</url>
  <url type="bugtracker">https://github.com/bekirbergin/baysal-kalem/issues</url>
  <url type="vcs-browser">https://github.com/bekirbergin/baysal-kalem</url>
  <url type="translate">https://github.com/bekirbergin/baysal-kalem/tree/master/po</url>
  <content_rating type="oars-1.1" />
  <branding>
    <color type="primary" scheme_preference="light">#ff00ff</color>
    <color type="primary" scheme_preference="dark">#993d3d</color>
  </branding>
  <screenshots>
    <screenshot type="default">
      <image>https://apps.pardus.org.tr/files/screenshots/pardus-pen/pardus-pen-1.png</image>
      <caption>Baysal Kalem</caption>
    </screenshot>
    <screenshot>
      <image>https://apps.pardus.org.tr/files/screenshots/pardus-pen/pardus-pen-2.png</image>
      <caption>Change Baysal Kalem size and color</caption>
    </screenshot>
    <screenshot>
      <image>https://apps.pardus.org.tr/files/screenshots/pardus-pen/pardus-pen-3.png</image>
      <caption>Baysal Kalem with background options</caption>
    </screenshot>
  </screenshots>
  <releases>
    <release version="@VERSION@" date="@DATE@"/>
  </releases>
</component>
